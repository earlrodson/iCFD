# Catholic Faith Defender PWA Environment Configuration

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# PWA Configuration
NEXT_PUBLIC_APP_NAME=Catholic Faith Defender
NEXT_PUBLIC_APP_DESCRIPTION=Progressive Web Application for Catholic apologetics content
NEXT_PUBLIC_APP_VERSION=1.0.0

# Environment
NODE_ENV=development

# =============================================================================
# OPTIONAL ANALYTICS & MONITORING
# =============================================================================

# Google Analytics (Optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager (Optional)
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Sentry Error Monitoring (Optional)
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn-here.ingest.sentry.io/project-id

# =============================================================================
# CONTENT & SEARCH CONFIGURATION
# =============================================================================

# Default Language (en, tl, ceb)
DEFAULT_LANGUAGE=en

# Enable search indexing
ENABLE_SEARCH_INDEXING=true

# Content caching duration (in hours)
CONTENT_CACHE_DURATION=24

# =============================================================================
# PWA & OFFLINE CONFIGURATION
# =============================================================================

# Service Worker Configuration
NEXT_PUBLIC_SW_URL=/sw.js
NEXT_PUBLIC_SW_SCOPE=/

# PWA Installation Settings
NEXT_PUBLIC_APP_ID=catholic-faith-defender
NEXT_PUBLIC_APP_SHORT_NAME=CatholicDefender

# Offline Configuration
OFFLINE_MODE_SUPPORTED=true
OFFLINE_CACHE_MAX_AGE_MS=86400000  # 24 hours

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Development server port
PORT=3000

# Enable debug logging in development
DEBUG_MODE=true

# Skip content validation in development (for faster builds)
SKIP_CONTENT_VALIDATION=false

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================

# Jest configuration
CI=false
COVERAGE_THRESHOLD=70

# Test database (for future integration tests)
TEST_DATABASE_URL=sqlite::memory:

# =============================================================================
# FUTURE CLOUD INTEGRATION (Phase 2)
# =============================================================================

# Supabase Configuration (when implemented)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Authentication Configuration (when implemented)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-nextauth-secret

# =============================================================================
# NOTES
# =============================================================================

# This application is designed to be fully offline-first and does NOT require
# any external API keys or services for basic functionality.

# Required services:
# - None (all content is served statically and stored in IndexedDB)

# Optional services:
# - Google Analytics: For usage tracking and analytics
# - Sentry: For error monitoring and performance tracking
# - Supabase: For future cloud sync and authentication features

# The application uses:
# - IndexedDB for offline content storage
# - MiniSearch for client-side search functionality
# - Service Worker for PWA offline capabilities
# - Static JSON files for content delivery